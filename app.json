{
  "expo": {
    "name": "Alakamanda HMS",
    "slug": "alkm-hms-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/alkm-logo.png",
    "scheme": "alkmhmsmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/alkm-logo.png",
      "bundleIdentifier": "com.it24103959.alkmhmsmobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1b2a4a",
        "foregroundImage": "./assets/alkm-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.it24103959.alkmhmsmobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1b2a4a",
          "image": "./assets/alkm-logo.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/alkm-logo.png",
            "imageWidth": 200
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "50064ecc-0faa-4492-9534-6dd810a8c4e3"
      }
    },
    "owner": "it24103959"
  }
}
